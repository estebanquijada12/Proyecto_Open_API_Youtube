{
  "openapi": "3.0.3",
  "info": {
    "title": "API de Catálogo Editorial y Derechos",
    "description": "Define qué contenido existe públicamente, su metadata editorial y las reglas de visibilidad aplicadas. Actúa como la fuente de verdad de la plataforma para la presentación de contenido al usuario final.\n\n**Integración Asíncrona:** Emite eventos de visibilidad hacia Descubrimiento, Monetización y Publicidad. Las dependencias asíncronas se documentan mediante `x-emitted-events` y `x-consumed-events`.\n\n**Autenticación y Red:** Se asume que el API Gateway inyecta las cabeceras `X-User-Id` y `X-User-Role` tras validar el Bearer Token.",
    "version": "1.3.0",
    "x-consumed-events": [
      {
        "schema": { "$ref": "#/components/schemas/EventAssetListoParaPublicacion" },
        "description": "Proviene de Publicación (API 1). Indica que el archivo físico asociado a un borrador ya está codificado y listo. El Catálogo puede transicionar el estado a 'Publicado' automáticamente si las reglas editoriales lo permiten."
      }
    ]
  },
  "servers": [
    {
      "url": "/api/v1/catalog",
      "description": "Servidor principal del catálogo editorial"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Channels", "description": "Gestión de canales y perfiles públicos." },
    { "name": "Items", "description": "Creación, edición y publicación de metadata de contenido." },
    { "name": "Playlists", "description": "Colecciones ordenadas de contenido curado." },
    { "name": "Rights", "description": "Derechos de autor, reclamaciones legales y políticas de moderación." }
  ],
  "paths": {
    "/categories": {
      "get": {
        "tags": ["Items"],
        "summary": "Listar categorías editoriales maestras",
        "security": [],
        "operationId": "listCategories",
        "responses": {
          "200": {
            "description": "Lista estática de categorías disponibles para clasificar contenido.",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Category" } }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/channels": {
      "post": {
        "tags": ["Channels"],
        "summary": "Crear un canal de publicación",
        "operationId": "createChannel",
        "parameters": [
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ChannelCreatePayload" } }
          }
        },
        "responses": {
          "201": {
            "description": "Canal creado exitosamente.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ChannelProfile" } }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" }
        }
      }
    },
    "/channels/{channelId}": {
      "put": {
        "tags": ["Channels"],
        "summary": "Actualizar información pública del canal",
        "operationId": "updateChannel",
        "parameters": [
          { "name": "channelId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ChannelUpdatePayload" } }
          }
        },
        "responses": {
          "200": { "description": "Metadata del canal actualizada." },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      },
      "get": {
        "tags": ["Channels"],
        "summary": "Consultar perfil de canal",
        "security": [],
        "operationId": "getChannelProfile",
        "parameters": [
          { "name": "channelId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Metadata pública del canal retornada.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ChannelProfile" } }
            }
          },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    },
    "/channels/{channelId}/items": {
      "get": {
        "tags": ["Channels", "Items"],
        "summary": "Listar contenido publicado de un canal",
        "security": [],
        "operationId": "listChannelItems",
        "parameters": [
          { "name": "channelId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "maximum": 100, "default": 20 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "minimum": 0, "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "Lista paginada de ítems editoriales visibles.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/CatalogItem" } },
                    "nextOffset": { "type": "integer", "nullable": true }
                  }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    },
    "/items": {
      "post": {
        "tags": ["Items"],
        "summary": "Crear entidad editorial en borrador",
        "operationId": "createItemDraft",
        "parameters": [
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ItemDraftPayload" } }
          }
        },
        "responses": {
          "201": {
            "description": "Borrador editorial creado a la espera del Asset Técnico.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/CatalogItem" } }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" }
        }
      }
    },
    "/items/{itemId}": {
      "put": {
        "tags": ["Items"],
        "summary": "Editar metadata de un contenido",
        "operationId": "updateItem",
        "x-emitted-events": [
          { "$ref": "#/components/schemas/EventContenidoActualizado" }
        ],
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "If-Match", "in": "header", "required": true, "schema": { "type": "string" }, "description": "ETag para control de concurrencia optimista." },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ItemUpdatePayload" } }
          }
        },
        "responses": {
          "200": { "description": "Metadatos actualizados." },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "412": { "description": "Conflicto de concurrencia. El recurso fue modificado por otro proceso." }
        }
      },
      "get": {
        "tags": ["Items"],
        "summary": "Consultar detalles del ítem editorial",
        "security": [],
        "operationId": "getItem",
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Objeto completo del ítem.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/CatalogItem" } }
            }
          },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      },
      "delete": {
        "tags": ["Items"],
        "summary": "Destrucción lógica del catálogo",
        "operationId": "deleteItem",
        "x-emitted-events": [
          { "$ref": "#/components/schemas/EventContenidoEliminado" }
        ],
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "responses": {
          "204": { "description": "Ítem destruido lógicamente. Gatilla purga en cascada." },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    },
    "/items/{itemId}/thumbnail": {
      "patch": {
        "tags": ["Items"],
        "summary": "Vincular miniatura externa",
        "description": "Asocia una imagen de portada al ítem editorial. Este contexto no almacena binarios; recibe una URI de una imagen ya cargada en un CDN o servicio de almacenamiento subyacente.",
        "operationId": "linkThumbnail",
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "thumbnailUrl": { "type": "string", "format": "uri" } },
                "required": ["thumbnailUrl"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Miniatura enlazada correctamente." },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    },
    "/items/{itemId}/publish": {
      "post": {
        "tags": ["Items"],
        "summary": "Aprobar y publicar un contenido",
        "operationId": "publishItem",
        "x-emitted-events": [
          { "$ref": "#/components/schemas/EventContenidoPublicado" }
        ],
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "responses": {
          "200": { "description": "Estado transicionado a 'published'." },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" },
          "409": { "description": "Conflicto: Falta el technicalAssetId o existen restricciones que bloquean la publicación." }
        }
      }
    },
    "/items/{itemId}/unpublish": {
      "post": {
        "tags": ["Items"],
        "summary": "Ocultar contenido públicamente",
        "operationId": "unpublishItem",
        "x-emitted-events": [
          { "$ref": "#/components/schemas/EventContenidoDespublicado" }
        ],
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "responses": {
          "200": { "description": "Estado regresado a borrador. Emite orden de desindexación al resto de la plataforma." },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" }
        }
      }
    },
    "/items/{itemId}/visibility": {
      "get": {
        "tags": ["Items", "Rights"],
        "summary": "Consultar motor de reglas de visibilidad",
        "security": [ { "bearerAuth": [] }, {} ],
        "description": "Endpoint altamente cacheable consultado por la CDN y otros servicios (como la App de reproducción) para evaluar si un usuario final tiene permiso de visualizar este ítem, procesando bloqueos regionales, límites de edad y sanciones del canal.",
        "operationId": "checkItemVisibility",
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Veredicto de visibilidad generado.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "isAllowed": { "type": "boolean" },
                    "reason": { "type": "string", "example": "blocked_geo_restriction" },
                    "technicalAssetId": { "type": "string", "nullable": true }
                  }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    },
    "/playlists": {
      "post": {
        "tags": ["Playlists"],
        "summary": "Crear una colección de ítems",
        "operationId": "createPlaylist",
        "parameters": [
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/PlaylistCreatePayload" } }
          }
        },
        "responses": {
          "201": {
            "description": "Colección creada exitosamente.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Playlist" } }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" }
        }
      }
    },
    "/playlists/{playlistId}/items": {
      "put": {
        "tags": ["Playlists"],
        "summary": "Actualizar índice de la colección",
        "operationId": "updatePlaylistItems",
        "parameters": [
          { "name": "playlistId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/PlaylistItemsUpdatePayload" } }
          }
        },
        "responses": {
          "200": { "description": "Orden y composición de la colección sincronizados." },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      },
      "get": {
        "tags": ["Playlists"],
        "summary": "Consultar ítems de una playlist",
        "security": [],
        "operationId": "getPlaylistItems",
        "parameters": [
          { "name": "playlistId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "maximum": 200, "default": 50 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "minimum": 0, "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "Listado de ítems retornados respetando el índice del creador.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/CatalogItem" } },
                    "nextOffset": { "type": "integer", "nullable": true }
                  }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    },
    "/items/{itemId}/claims": {
      "post": {
        "tags": ["Rights"],
        "summary": "Registrar reclamación por derechos",
        "operationId": "createClaim",
        "x-emitted-events": [
          { "$ref": "#/components/schemas/EventReclamacionDerechosCreada" }
        ],
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ClaimCreatePayload" } }
          }
        },
        "responses": {
          "201": {
            "description": "Reclamación levantada en los registros del catálogo.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/CopyrightClaim" } }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      },
      "get": {
        "tags": ["Rights"],
        "summary": "Consultar auditoría de reclamaciones",
        "operationId": "listClaims",
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "responses": {
          "200": {
            "description": "Historial inmutable de reclamaciones sobre este ítem.",
            "content": {
              "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CopyrightClaim" } } }
            }
          },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    },
    "/items/{itemId}/claims/{claimId}/resolve": {
      "put": {
        "tags": ["Rights"],
        "summary": "Transicionar estado de reclamación",
        "operationId": "resolveClaim",
        "x-emitted-events": [
          { "$ref": "#/components/schemas/EventReclamacionResuelta" }
        ],
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "claimId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ClaimResolvePayload" } }
          }
        },
        "responses": {
          "202": { "description": "Fallo legal asimilado por el motor del Catálogo." },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    },
    "/items/{itemId}/restrictions": {
      "post": {
        "tags": ["Rights"],
        "summary": "Sancionar o restringir ítem",
        "operationId": "applyRestriction",
        "x-emitted-events": [
          { "$ref": "#/components/schemas/EventRestriccionAplicada" }
        ],
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/RestrictionCreatePayload" } }
          }
        },
        "responses": {
          "201": {
            "description": "Política de restricción inyectada en el motor de reglas.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PolicyRestriction" } }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" }
        }
      },
      "get": {
        "tags": ["Rights"],
        "summary": "Consultar registro de sanciones",
        "operationId": "listRestrictions",
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "responses": {
          "200": {
            "description": "Registro histórico de intervenciones y restricciones.",
            "content": {
              "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/PolicyRestriction" } } }
            }
          },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    },
    "/items/{itemId}/restrictions/{restrictionId}/status": {
      "put": {
        "tags": ["Rights"],
        "summary": "Absolver o levantar restricción",
        "operationId": "updateRestrictionStatus",
        "x-emitted-events": [
          { "$ref": "#/components/schemas/EventRestriccionLevantada" }
        ],
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "restrictionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "$ref": "#/components/parameters/UserIdHeader" },
          { "$ref": "#/components/parameters/UserRoleHeader" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/RestrictionStatusUpdatePayload" } }
          }
        },
        "responses": {
          "200": { "description": "Castigo removido de las directrices del motor." },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "$ref": "#/components/responses/ForbiddenError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "parameters": {
      "UserIdHeader": {
        "name": "X-User-Id",
        "in": "header",
        "required": true,
        "schema": { "type": "string" },
        "description": "Identificador del actor que solicita la operación (ej. el dueño del canal o el ID del moderador), validado previamente por el API Gateway."
      },
      "UserRoleHeader": {
        "name": "X-User-Role",
        "in": "header",
        "required": true,
        "schema": { "type": "string", "enum": ["creator", "moderator", "internal_service"] },
        "description": "Perfil de privilegios del actor inyectado por el API Gateway para el control de acceso en la capa de negocio."
      }
    },
    "responses": {
      "ValidationError": {
        "description": "Estructura de metadatos inválida o formato rechazado.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "UnauthorizedError": {
        "description": "Ausencia del token JWT o credencial corrompida.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "ForbiddenError": {
        "description": "El actor superó la barrera de red pero el rol no permite modificar el recurso objetivo.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "NotFoundError": {
        "description": "La entidad editorial no existe en la base de datos.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "InternalError": {
        "description": "Fallo severo en el motor de persistencia o red.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "details": { "type": "array", "items": { "type": "object" } }
            }
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "categoryId": { "type": "string" },
          "name": { "type": "string", "example": "Educación" }
        }
      },
      "ChannelProfile": {
        "type": "object",
        "properties": {
          "channelId": { "type": "string" },
          "ownerId": { "type": "string" },
          "name": { "type": "string", "maxLength": 50 },
          "description": { "type": "string", "maxLength": 1000 },
          "avatarUrl": { "type": "string", "format": "uri" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "CatalogItem": {
        "type": "object",
        "properties": {
          "itemId": { "type": "string" },
          "channelId": { "type": "string" },
          "technicalAssetId": { "type": "string", "nullable": true },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "categoryId": { "type": "string" },
          "editorialStatus": { "type": "string", "enum": ["draft", "published", "unlisted"] },
          "moderationState": { "type": "string", "enum": ["clean", "restricted", "blocked"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "publishedAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "Playlist": {
        "type": "object",
        "properties": {
          "playlistId": { "type": "string" },
          "channelId": { "type": "string" },
          "title": { "type": "string" },
          "isPublic": { "type": "boolean" },
          "itemCount": { "type": "integer" }
        }
      },
      "PolicyRestriction": {
        "type": "object",
        "properties": {
          "restrictionId": { "type": "string" },
          "restrictionType": { "type": "string", "enum": ["age", "geo", "monetization_limited"] },
          "parameters": { "type": "object" },
          "status": { "type": "string", "enum": ["active", "lifted"] },
          "appliedBy": { "type": "string" },
          "appliedAt": { "type": "string", "format": "date-time" }
        }
      },
      "CopyrightClaim": {
        "type": "object",
        "properties": {
          "claimId": { "type": "string" },
          "claimantId": { "type": "string" },
          "claimType": { "type": "string" },
          "evidenceUrl": { "type": "string", "format": "uri" },
          "status": { "type": "string", "enum": ["pending", "accepted", "disputed", "withdrawn"] },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ChannelCreatePayload": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 3, "maxLength": 50 },
          "description": { "type": "string", "maxLength": 1000 },
          "avatarUrl": { "type": "string", "format": "uri" }
        },
        "required": ["name"]
      },
      "ChannelUpdatePayload": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 3, "maxLength": 50 },
          "description": { "type": "string", "maxLength": 1000 },
          "avatarUrl": { "type": "string", "format": "uri" }
        }
      },
      "ItemDraftPayload": {
        "type": "object",
        "properties": {
          "channelId": { "type": "string" },
          "title": { "type": "string", "minLength": 1, "maxLength": 100 },
          "description": { "type": "string", "maxLength": 5000 },
          "tags": { "type": "array", "maxItems": 30, "items": { "type": "string", "maxLength": 30 } },
          "categoryId": { "type": "string" },
          "thumbnailUrl": { "type": "string", "format": "uri", "nullable": true },
          "technicalAssetId": { "type": "string", "nullable": true }
        },
        "required": ["channelId", "title", "categoryId"]
      },
      "ItemUpdatePayload": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "minLength": 1, "maxLength": 100 },
          "description": { "type": "string", "maxLength": 5000 },
          "tags": { "type": "array", "maxItems": 30, "items": { "type": "string", "maxLength": 30 } },
          "thumbnailUrl": { "type": "string", "format": "uri", "nullable": true },
          "technicalAssetId": { "type": "string" }
        }
      },
      "PlaylistCreatePayload": {
        "type": "object",
        "properties": {
          "channelId": { "type": "string" },
          "title": { "type": "string", "minLength": 1, "maxLength": 100 },
          "isPublic": { "type": "boolean", "default": true }
        },
        "required": ["channelId", "title"]
      },
      "PlaylistItemsUpdatePayload": {
        "type": "object",
        "properties": {
          "orderedItemIds": { "type": "array", "maxItems": 5000, "items": { "type": "string" } }
        },
        "required": ["orderedItemIds"]
      },
      "ClaimCreatePayload": {
        "type": "object",
        "properties": {
          "claimantId": { "type": "string" },
          "claimType": { "type": "string", "enum": ["copyright", "trademark", "privacy"] },
          "evidenceUrl": { "type": "string", "format": "uri" }
        },
        "required": ["claimantId", "claimType"]
      },
      "ClaimResolvePayload": {
        "type": "object",
        "properties": {
          "resolution": { "type": "string", "enum": ["accepted", "disputed", "withdrawn"] }
        },
        "required": ["resolution"]
      },
      "RestrictionCreatePayload": {
        "type": "object",
        "properties": {
          "restrictionType": { "type": "string", "enum": ["age", "geo", "monetization_limited"] },
          "parameters": { "type": "object" }
        },
        "required": ["restrictionType"]
      },
      "RestrictionStatusUpdatePayload": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["active", "lifted"] }
        },
        "required": ["status"]
      },
      "EventContenidoPublicado": {
        "type": "object",
        "description": "Carga útil del mensaje emitido para informar que un ítem ha pasado a estado público.",
        "properties": {
          "eventId": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "itemId": { "type": "string" },
          "channelId": { "type": "string" },
          "categoryId": { "type": "string" },
          "technicalAssetId": { "type": "string" }
        },
        "required": ["eventId", "timestamp", "itemId", "channelId", "technicalAssetId"]
      },
      "EventContenidoDespublicado": {
        "type": "object",
        "description": "Carga útil del mensaje emitido para instruir la desindexación en buscadores y detener anuncios.",
        "properties": {
          "eventId": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "itemId": { "type": "string" }
        },
        "required": ["eventId", "timestamp", "itemId"]
      },
      "EventContenidoActualizado": {
        "type": "object",
        "description": "Carga útil del mensaje emitido al guardar metadatos modificados.",
        "properties": {
          "eventId": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "itemId": { "type": "string" },
          "updatedFields": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["eventId", "timestamp", "itemId", "updatedFields"]
      },
      "EventContenidoEliminado": {
        "type": "object",
        "description": "Carga útil del mensaje emitido para disparar la purga en cascada en API 1 y API 3.",
        "properties": {
          "eventId": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "itemId": { "type": "string" },
          "technicalAssetId": { "type": "string", "nullable": true }
        },
        "required": ["eventId", "timestamp", "itemId"]
      },
      "EventRestriccionAplicada": {
        "type": "object",
        "description": "Carga útil del mensaje emitido para notificar bloqueos a contextos de monetización o tendencias.",
        "properties": {
          "eventId": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "itemId": { "type": "string" },
          "restrictionType": { "type": "string" }
        },
        "required": ["eventId", "timestamp", "itemId", "restrictionType"]
      },
      "EventRestriccionLevantada": {
        "type": "object",
        "description": "Carga útil del mensaje emitido para reactivar visibilidad sin restricciones previas.",
        "properties": {
          "eventId": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "itemId": { "type": "string" },
          "restrictionType": { "type": "string" }
        },
        "required": ["eventId", "timestamp", "itemId", "restrictionType"]
      },
      "EventReclamacionDerechosCreada": {
        "type": "object",
        "description": "Carga útil del mensaje legal para iniciar una disputa sobre el ítem.",
        "properties": {
          "eventId": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "itemId": { "type": "string" },
          "claimId": { "type": "string" },
          "claimType": { "type": "string" }
        },
        "required": ["eventId", "timestamp", "itemId", "claimId", "claimType"]
      },
      "EventReclamacionResuelta": {
        "type": "object",
        "description": "Carga útil del mensaje legal que decreta si el ítem es penalizado o absuelto.",
        "properties": {
          "eventId": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "itemId": { "type": "string" },
          "claimId": { "type": "string" },
          "resolution": { "type": "string" }
        },
        "required": ["eventId", "timestamp", "itemId", "claimId", "resolution"]
      },
      "EventAssetListoParaPublicacion": {
        "type": "object",
        "description": "Carga útil que la API 2 ESPERA RECIBIR desde la API 1 para reaccionar.",
        "properties": {
          "eventId": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "assetId": { "type": "string" },
          "creatorId": { "type": "string" },
          "durationSeconds": { "type": "integer" }
        },
        "required": ["eventId", "timestamp", "assetId", "creatorId"]
      }
    }
  }
}