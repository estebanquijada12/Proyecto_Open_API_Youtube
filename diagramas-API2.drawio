<mxfile host="app.diagrams.net" pages="2">
  <diagram id="DDQ8_rG2vDudJReGNQWm" name="clases">
    <mxGraphModel dx="11320" dy="11390" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome true\nskinparam packageStyle rectangle\nskinparam linetype ortho\nskinparam nodesep 60\nskinparam ranksep 70\n\ntitle Class Diagram - Catalog &amp; Rights API (Rich Domain Model)\n\npackage \&quot;Catalog Entities &amp; Legal Rights\&quot; {\n    class CatalogItem &lt;&lt;AggregateRoot&gt;&gt; {\n        + itemId: UUID\n        + version: Integer\n        + technicalAssetId: UUID\n        + creatorId: String\n        + status: Enum {draft, published, restricted, archived}\n        + visibility: Enum {public, private, unlisted}\n        + metadata: EditorialMetadata\n        + applyPublishingRules(rules: PublishingCriteria): void\n        + processLegalClaim(claim: CopyrightClaim): void\n    }\n\n    class EditorialMetadata &lt;&lt;ValueObject&gt;&gt; {\n        + title: String\n        + description: String\n        + category: String\n        + tags: List&lt;String&gt;\n    }\n    \n    class CopyrightClaim &lt;&lt;Entity&gt;&gt; {\n        + claimId: String\n        + type: String\n        + resolution: String\n        + isActive: Boolean\n    }\n}\n\npackage \&quot;Domain Services &amp; Workflows\&quot; {\n    class EditorialWorkflowService &lt;&lt;DomainService&gt;&gt; {\n        + processAssetReadyEvent(assetId: UUID): void\n        + evaluatePublicationCriteria(item: CatalogItem): boolean\n    }\n    \n    class RightsManagementService &lt;&lt;DomainService&gt;&gt; {\n        + handleClaimResolution(claimId: String, resolution: String): void\n    }\n}\n\npackage \&quot;Infrastructure &amp; Event Handlers\&quot; {\n    class CatalogMessageConsumer &lt;&lt;Consumer&gt;&gt; {\n        + onAssetReady(event: EventAssetListoParaPublicacion): void\n        + onClaimResolved(event: EventReclamacionResuelta): void\n    }\n    \n    class VisibilityEventPublisher &lt;&lt;Publisher&gt;&gt; {\n        + broadcastVisibilityChange(item: CatalogItem): void\n    }\n}\n\n&#39; Relaciones\nCatalogItem *-- EditorialMetadata : \&quot;contains\&quot;\nCatalogItem \&quot;1\&quot; *-- \&quot;0..*\&quot; CopyrightClaim : \&quot;tracks\&quot;\n\nCatalogMessageConsumer --&gt; EditorialWorkflowService : \&quot;delegates asset events\&quot;\nCatalogMessageConsumer --&gt; RightsManagementService : \&quot;delegates claims\&quot;\n\nEditorialWorkflowService --&gt; CatalogItem : \&quot;mutates state\&quot;\nRightsManagementService --&gt; CatalogItem : \&quot;applies restrictions\&quot;\n\nCatalogItem --&gt; VisibilityEventPublisher : \&quot;triggers updates\&quot;\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="TbqBrV6ItJC9RdwUECVl-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="5416" width="8655.94" x="-3665" y="-5389" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome true\nskinparam packageStyle rectangle\n\ntitle Class Diagram - Catalog Message Broker Events\n\npackage \&quot;Integration Events\&quot; {\n\n    abstract class DomainEvent &lt;&lt;Event&gt;&gt; {\n        + eventId: UUID\n        + timestamp: DateTime\n    }\n\n    class EventReclamacionCreada &lt;&lt;Emitted&gt;&gt; {\n        + itemId: UUID\n        + claimId: UUID\n        + claimType: String\n    }\n\n    class EventReclamacionResuelta &lt;&lt;Emitted&gt;&gt; {\n        + itemId: UUID\n        + claimId: UUID\n        + resolution: String\n    }\n\n    class EventAssetListoParaPublicacion &lt;&lt;Consumed&gt;&gt; {\n        + assetId: UUID\n        + creatorId: String\n        + durationSeconds: Integer\n    }\n\n    &#39; --- Inheritance ---\n    DomainEvent &lt;|-- EventReclamacionCreada\n    DomainEvent &lt;|-- EventReclamacionResuelta\n    DomainEvent &lt;|-- EventAssetListoParaPublicacion\n}\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="TbqBrV6ItJC9RdwUECVl-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="2569" width="5614.02" x="-3683" y="66" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="nAHpC_yz_rBMnKTI3ofD" name="secuencia">
    <mxGraphModel dx="1627" dy="967" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam monochrome true\nskinparam style strictuml\nskinparam defaultFontName Arial\nskinparam participantPadding 20\n\ntitle Diagrama de Secuencia: Catálogo y Derechos \n\nactor \&quot;Creador / Moderador\&quot; as User\nparticipant \&quot;Catalog API\&quot; as API\ndatabase \&quot;Catalog DB\&quot; as DB\nqueue \&quot;Message Broker\&quot; as Broker\nparticipant \&quot;Publishing API\\n(Contexto 1)\&quot; as API1\n\n== Flujo Alternativo: Bloqueo de Publicación Prematura ==\nUser -&gt; API: POST /items/{itemId}/publish\nAPI -&gt; DB: Verificar estado técnico\nAPI --&gt; User: 409 Conflict (El asset técnico aún no está listo)\n\n== Flujo Alternativo: Concurrencia Optimista (Colisión) ==\nUser -&gt; API: PUT /items/{itemId} (If-Match: v1)\nAPI -&gt; DB: Validar versión actual\nnote over API, DB: Otro moderador ya actualizó a v2\nAPI --&gt; User: 412 Precondition Failed (Metadata obsoleta)\n\n== Integración Asíncrona: Recepción Exitosa ==\nBroker -&gt; API: Event: AssetReadyForPublication\nAPI -&gt; DB: Crear/Actualizar Item (Estado: Draft, TechnicalAssetId)\n\n== Resiliencia: Proceso de Conciliación (Cron Job) ==\nnote over API, API1: Si el evento del Broker se pierde...\nloop Cada 30 minutos\n    API -&gt; DB: Buscar ítems \&quot;Draft\&quot; antiguos\n    API -&gt; API1: GET /assets/{technicalAssetId} (Consulta Síncrona de rescate)\n    API1 --&gt; API: 200 OK (Status: ready)\n    API -&gt; DB: Actualizar estado local a \&quot;AssetReady\&quot;\nend\n\n== Metadata &amp; Publicación Exitosa ==\nUser -&gt; API: PUT /items/{itemId} (If-Match: v2)\nAPI -&gt; DB: Guardar cambios y subir versión (v3)\nAPI --&gt; User: 200 OK\n\nUser -&gt; API: POST /items/{itemId}/publish\nAPI -&gt; DB: Cambiar estado a \&quot;Published\&quot;\nAPI --&gt;&gt; Broker: Event: ContentPublished\nAPI --&gt; User: 200 OK\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="5478RmiIqJbviCEnQxG6-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="980" width="1153" x="-53" y="10" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
