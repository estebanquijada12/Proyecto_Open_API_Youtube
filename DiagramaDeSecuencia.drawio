<mxfile host="app.diagrams.net">
  <diagram name="Página-1" id="mrda8BOO0gRi-AJnwvVp">
    <mxGraphModel dx="1662" dy="915" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Escenario Integrador: Flujo de Visualización, Publicidad e Ingresos\\nAPIs de Dominio (Tus Bounded Contexts)\n\n&#39;&#39; Definición de participantes (Cambiado Espectador por Orquestador)\nactor Orquestador as \&quot;Orquestador\&quot;\nparticipant API3 as \&quot;API 3: Descubrimiento\&quot;\nparticipant API2 as \&quot;API 2: Catálogo\&quot;\nparticipant API6 as \&quot;API 6: Publicidad\&quot;\nparticipant API1 as \&quot;API 1: Publicación\&quot;\nparticipant API4 as \&quot;API 4: Audiencia\&quot;\nparticipant API5 as \&quot;API 5: Monetización\&quot;\n\n&#39;&#39; --- FLUJO DE FEED Y RECOMENDACIONES ---\nOrquestador -&gt; API3: 1 Solicitar feed de inicio personalizado\\n(GET /feed/home)\nnote over API3, API2: Consulta síncrona interna para validar reglas del catálogo (RNF-4)\nAPI3 -&gt; API2: 2 Validar si los items candidatos son visibles\\n(GET /items/{itemId}/visibility)\nAPI2 --&gt; API3: 3 Retorna veredicto de acceso con asset técnico\\n(Allowed: true)\nAPI3 --&gt; Orquestador: 4 Entrega lista de videos recomendados\\n(DiscoveryItemList)\n\n&#39;&#39; --- FLUJO DE PUBLICIDAD ---\nOrquestador -&gt; API6: 5 Solicitar anuncio elegible para el reproductor\\n(POST /delivery/decide)\nAPI6 --&gt; Orquestador: 6 Retorna URL del asset publicitario\\n(AdDecisionResponse)\n\nOrquestador -&gt; API6: 7 Registrar visualización/impresión del anuncio\\n(POST /delivery/interactions)\nAPI6 -&gt; API5: 8 Emitir evento de cobro al anunciante\\n(IngresoPublicitarioConfirmadoEvent)\nnote over API5: Registra el ingreso (Earning)\\ny calcula el reparto con el creador (RF-M3)\n\n&#39;&#39; --- FLUJO DE REPRODUCCIÓN Y TELEMETRÍA ---\nOrquestador -&gt; API1: 9 Solicitar manifiestos técnicos del video\\n(GET /assets/{assetId}/playback)\nAPI1 --&gt; Orquestador: 10 Retorna flujos de streaming empaquetados\\n(HLS/DASH)\n\nOrquestador -&gt; API1: 11 Enviar telemetría de finalización al cerrar el video\\n(POST /assets/{assetId}/telemetry)\nAPI1 -&gt; API3: 12 Notificar datos agregados de la reproducción\\n(SesionReproduccionCompletadaEvent)\nnote over API3: Indexa la señal de WATCH_TIME\\npara ajustar futuras recomendaciones (RF-D5)\n\n&#39;&#39; --- FLUJO DE INTERACCIÓN SOCIAL ---\nOrquestador -&gt; API4: 13 Registrar reacción positiva en el contenido\\n(PUT /targets/{targetId}/reactions)\nAPI4 --&gt; Orquestador: 14 Confirma el estado actualizado de la reacción\\n(ReactionResponse)\n\n@endum&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="A7uwlCDbr_1OnTrtJbWB-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="945" width="1388" x="230" y="270" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
