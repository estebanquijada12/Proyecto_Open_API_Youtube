        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    direction TB\n    class Elegibilidad {\n        +String status\n        +Integer subscriberCount\n        +Integer watchHours\n        +Boolean policyCompliance\n        +consultarEstado()\n        +solicitarIngreso()\n    }\n    class ConfiguracionCanal {\n        +UUID channelReferenceId\n        +Boolean isMonetizationEnabled\n        +DateTime updatedAt\n        +actualizarConfiguracion()\n    }\n    class ConfiguracionItem {\n        +UUID catalogReferenceId\n        +Boolean isAdsEnabled\n        +Boolean isTipsEnabled\n        +DateTime updatedAt\n        +actualizarMonetizacionItem()\n    }\n    class NivelMembresia {\n        +UUID tierId\n        +String name\n        +Float priceValue\n        +String priceCurrency\n        +List~String~ benefits\n        +crearNivel()\n        +listarNiveles()\n    }\n    class Ganancia {\n        +UUID earningId\n        +UUID catalogReferenceId\n        +String source\n        +String status\n        +Float amountValue\n        +String amountCurrency\n        +Float rpmValue\n        +Integer monetizedViews\n        +DateTime recordedAt\n        +consultarDesglose()\n        +exportarReporte()\n    }\n    class Saldo {\n        +Float availableValue\n        +Float pendingValue\n        +String currency\n        +Boolean thresholdReached\n        +consultarSaldos()\n    }\n    class DocumentoFiscal {\n        +UUID documentId\n        +String documentType\n        +String status\n        +DateTime uploadedAt\n        +subirDocumento()\n        +listarDocumentos()\n    }\n    class Pago {\n        +UUID payoutId\n        +String status\n        +Float amountValue\n        +String amountCurrency\n        +DateTime requestedAt\n        +solicitarRetiro()\n        +listarPagos()\n    }\n    ConfiguracionCanal ..&gt; Elegibilidad : Habilitación requiere estado APTO\n    ConfiguracionItem \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Ganancia : Atribución por catalogReferenceId\n    NivelMembresia \&quot;1\&quot; --&gt; \&quot;*\&quot; Ganancia : Clasifica origen de tipo MEMBERSHIP\n    Ganancia \&quot;*\&quot; --&gt; \&quot;1\&quot; Saldo : Incrementa balance financiero\n    Pago \&quot;*\&quot; --&gt; \&quot;1\&quot; Saldo : Debita del balance disponible\n    Pago ..&gt; DocumentoFiscal : Exige verificación previa para liberar fondos&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="yQFNmiLlT6qhnsJeKwDJ-1">
