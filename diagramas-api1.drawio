<mxfile host="app.diagrams.net" pages="2">
  <diagram id="DDQ8_rG2vDudJReGNQWm" name="clases">
    <mxGraphModel dx="5680" dy="6660" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome true\nskinparam packageStyle rectangle\nskinparam linetype ortho\nskinparam nodesep 50\nskinparam ranksep 60\n\ntitle Class Diagram - Publishing API (Core &amp; Data)\n\npackage \&quot;API Resources (Controllers)\&quot; {\n    \n    class UploadAPI &lt;&lt;Resource&gt;&gt; {\n      + initiateUpload(creatorId: String): UploadSession\n      + getUploadProgress(assetId: String, creatorId: String): UploadSession\n      + cancelUpload(assetId: String, creatorId: String): void\n      + uploadChunk(assetId: String, chunkNumber: Integer, chunkData: Binary, creatorId: String): void\n      + completeUpload(assetId: String, creatorId: String): void\n    }\n\n    class AssetsAPI &lt;&lt;Resource&gt;&gt; {\n      + listAssets(limit: Integer, offset: Integer, creatorId: String): List&lt;TechnicalAsset&gt;\n      + getAssetDetails(assetId: String, creatorId: String): TechnicalAsset\n      + retryProcessing(assetId: String, creatorId: String): void\n    }\n\n    class PlaybackAPI &lt;&lt;Resource&gt;&gt; {\n      + getPlaybackManifests(assetId: String, playbackToken: String, deviceProfile: String, viewerId: String): ManifestResponse\n      + recordTelemetry(assetId: String, telemetry: TelemetryPayload): void\n    }\n\n    class LiveAPI &lt;&lt;Resource&gt;&gt; {\n      + configureLiveStream(creatorId: String): LiveStream\n      + updateLiveState(liveId: String, transition: LiveStateTransition, creatorId: String): LiveStream\n    }\n}\n\npackage \&quot;Data Entities (Schemas)\&quot; {\n\n    class TechnicalAsset &lt;&lt;DTO&gt;&gt; {\n      + assetId: UUID\n      + creatorId: String\n      + uploadStatus: Enum {pending, uploading, completed, cancelled}\n      + processingStatus: Enum {pending, processing, ready, failed}\n      + durationSeconds: Integer\n      + sizeBytes: Integer\n      + availableQualities: List&lt;String&gt;\n    }\n\n    class UploadSession &lt;&lt;DTO&gt;&gt; {\n      + assetId: String\n      + chunkSizeLimitMb: Integer\n      + receivedChunks: List&lt;Integer&gt;\n      + lastActivity: DateTime\n    }\n\n    class LiveStream &lt;&lt;DTO&gt;&gt; {\n      + liveId: String\n      + creatorId: String\n      + streamKey: String\n      + ingestUrl: URI\n      + state: Enum {configured, live, paused, ended}\n      + vodAssetId: String\n    }\n\n    class TelemetryPayload &lt;&lt;DTO&gt;&gt; {\n      + viewerSessionId: String\n      + eventAction: Enum {start, heartbeat, pause, error, end}\n      + playbackPositionSeconds: Integer\n      + currentQuality: String\n      + bufferingEventsCount: Integer\n    }\n\n    class LiveStateTransition &lt;&lt;DTO&gt;&gt; {\n      + action: Enum {start, pause, end}\n    }\n\n    class ErrorResponse &lt;&lt;DTO&gt;&gt; {\n      + code: String\n      + message: String\n      + details: List&lt;Object&gt;\n    }\n}\n\n&#39; --- Standard UML Relationships ---\n\nUploadAPI ..&gt; UploadSession : creates/updates\nAssetsAPI ..&gt; TechnicalAsset : reads/updates\nLiveAPI ..&gt; LiveStream : configures\nLiveAPI ..&gt; LiveStateTransition : consumes\nPlaybackAPI ..&gt; TelemetryPayload : consumes\n\nUploadSession \&quot;1\&quot; --&gt; \&quot;1\&quot; TechnicalAsset : manages upload of\nLiveStream \&quot;1\&quot; --&gt; \&quot;0..1\&quot; TechnicalAsset : generates VOD\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="s4js0qg3NA0bRp_5JxE_-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="2086" width="9503.59" x="-732" y="-2562" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome true\nskinparam packageStyle rectangle\nskinparam linetype ortho\nskinparam nodesep 50\nskinparam ranksep 60\n\ntitle Class Diagram - Message Broker Events\n\npackage \&quot;Message Broker Events (x-emitted-events)\&quot; {\n\n    abstract class DomainEvent &lt;&lt;Event&gt;&gt; {\n      + eventId: String\n      + timestamp: DateTime\n    }\n\n    class UploadCompletedEvent {\n      + assetId: String\n      + creatorId: String\n      + sizeBytes: Integer\n    }\n\n    class ProcessingFinishedEvent {\n      + assetId: String\n      + status: Enum {success, failed}\n      + errorReason: String\n    }\n\n    class AssetReadyForPublicationEvent {\n      + assetId: String\n      + creatorId: String\n      + durationSeconds: Integer\n      + formats: List&lt;String&gt;\n    }\n\n    class PlaybackSessionCompletedEvent {\n      + assetId: String\n      + viewerId: String\n      + totalWatchTimeSeconds: Integer\n    }\n\n    class LiveStreamStartedEvent {\n      + liveId: String\n      + creatorId: String\n    }\n\n    class LiveStreamEndedEvent {\n      + liveId: String\n      + vodAssetId: String\n    }\n\n    &#39; --- Standard UML Inheritance ---\n    DomainEvent &lt;|-- UploadCompletedEvent\n    DomainEvent &lt;|-- ProcessingFinishedEvent\n    DomainEvent &lt;|-- AssetReadyForPublicationEvent\n    DomainEvent &lt;|-- PlaybackSessionCompletedEvent\n    DomainEvent &lt;|-- LiveStreamStartedEvent\n    DomainEvent &lt;|-- LiveStreamEndedEvent\n}\n\n&#39; --- External References for Context ---\nclass TechnicalAsset &lt;&lt;DTO&gt;&gt;\nclass LiveStream &lt;&lt;DTO&gt;&gt;\n\nUploadCompletedEvent ..&gt; TechnicalAsset : references\nAssetReadyForPublicationEvent ..&gt; TechnicalAsset : references\nLiveStreamEndedEvent ..&gt; LiveStream : references\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="s4js0qg3NA0bRp_5JxE_-3">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1517.24" width="5164.7" x="-726" y="-456" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="nAHpC_yz_rBMnKTI3ofD" name="secuencia">
    <mxGraphModel dx="771" dy="609" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam monochrome true\nskinparam style strictuml\nskinparam defaultFontName Arial\nskinparam participantPadding 20\n\ntitle Diagrama de Secuencia: Sincronía vs Asincronía\n\nactor \&quot;Client\&quot; as Client\nparticipant \&quot;API Service\&quot; as API\nqueue \&quot;Message Broker\&quot; as Broker\n\n== Synchronous: Client-API Interaction (Blocking) ==\nClient -&gt; API: GET /assets/{assetId}\nAPI --&gt; Client: 200 OK (Technical Asset Details)\n\nClient -&gt; API: POST /lives\nAPI --&gt; Client: 201 Created (Configured LiveStream)\n\n== Asynchronous: Integration Events (Fire-and-Forget) ==\nnote over API, Broker: Background processing triggers\nClient -&gt; API: POST /assets/{assetId}/upload/complete\nAPI --&gt;&gt; Broker: Emit(UploadCompleted)\nAPI --&gt;&gt; Broker: Emit(ProcessingFinished)\nAPI --&gt;&gt; Broker: Emit(AssetReady)\nAPI --&gt; Client: 202 Accepted (Processing Started)\n\n== Asynchronous: Telemetry Ingestion ==\nClient -&gt; API: POST /assets/{assetId}/telemetry\nAPI --&gt;&gt; Broker: Emit(PlaybackSessionCompleted)\nAPI --&gt; Client: 204 No Content (Ingested)\n\n== Asynchronous: Live Stream Workflow ==\nClient -&gt; API: PUT /lives/{liveId}/state (end)\nAPI --&gt;&gt; Broker: Emit(TransmisionEnVivoFinalizada)\nAPI --&gt; Client: 200 OK (Stream Ended)\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="xmi8cS3HOA-LV78vGN9y-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="763" width="610" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
