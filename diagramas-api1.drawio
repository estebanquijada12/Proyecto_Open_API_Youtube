<mxfile host="app.diagrams.net" pages="2">
  <diagram id="DDQ8_rG2vDudJReGNQWm" name="clases">
    <mxGraphModel dx="15440" dy="17980" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome true\nskinparam packageStyle rectangle\nskinparam linetype ortho\nskinparam nodesep 60\nskinparam ranksep 70\n\ntitle Class Diagram - Publishing API (Rich Domain Model)\n\npackage \&quot;API Resources (Controllers)\&quot; {\n    \n    class UploadAPI &lt;&lt;Resource&gt;&gt; {\n      + initiateUpload(): UploadSession\n      + getUploadProgress(assetId: String): UploadSession\n      + cancelUpload(assetId: String): void\n      + uploadChunk(assetId: String, chunkNumber: Integer, chunkData: Binary): void\n      + completeUpload(assetId: String): void\n    }\n\n    class AssetsAPI &lt;&lt;Resource&gt;&gt; {\n      + listAssets(limit: Integer, offset: Integer): List&lt;TechnicalAsset&gt;\n      + getAssetDetails(assetId: String): TechnicalAsset\n      + retryProcessing(assetId: String): void\n    }\n\n    class PlaybackAPI &lt;&lt;Resource&gt;&gt; {\n      + getPlaybackManifests(assetId: String, playbackToken: String, deviceProfile: String, viewerId: String): ManifestResponse\n      + recordTelemetry(assetId: String, telemetry: TelemetryPayload): void\n    }\n\n    class LiveAPI &lt;&lt;Resource&gt;&gt; {\n      + configureLiveStream(): LiveStream\n      + updateLiveState(liveId: String, transition: LiveStateTransition): LiveStream\n    }\n}\n\npackage \&quot;Application &amp; Infrastructure Services\&quot; {\n    \n    class GarbageCollectorService &lt;&lt;BackgroundJob&gt;&gt; {\n      + purgeStaleSessions(ttlHours: Integer): void\n    }\n\n    class TranscodingEngine &lt;&lt;Service&gt;&gt; {\n      + enqueueForAssembly(assetId: String): void\n      + dispatchWorkers(assetId: String): void\n    }\n\n    class LiveStateEngine &lt;&lt;Service&gt;&gt; {\n      + transitionState(liveId: String, action: Enum): void\n      + terminateRtmpStream(liveId: String): void\n    }\n\n    class TokenValidator &lt;&lt;ExternalGateway&gt;&gt; {\n      + verifyPlaybackToken(token: String): boolean\n    }\n}\n\npackage \&quot;Data Entities &amp; DTOs\&quot; {\n\n    class TechnicalAsset &lt;&lt;Entity&gt;&gt; {\n      + assetId: UUID\n      + creatorId: String\n      + uploadStatus: Enum {pending, uploading, completed, cancelled}\n      + processingStatus: Enum {pending, processing, ready, failed}\n      + durationSeconds: Integer\n      + sizeBytes: Integer\n      + availableQualities: List&lt;String&gt;\n    }\n\n    class UploadSession &lt;&lt;Entity&gt;&gt; {\n      + assetId: String\n      + chunkSizeLimitMb: Integer\n      + receivedChunks: List&lt;Integer&gt;\n      + lastActivity: DateTime\n    }\n\n    class LiveStream &lt;&lt;Entity&gt;&gt; {\n      + liveId: String\n      + creatorId: String\n      + streamKey: String\n      + ingestUrl: URI\n      + state: Enum {configured, live, paused, ended}\n      + vodAssetId: String\n    }\n    \n    class ManifestResponse &lt;&lt;DTO&gt;&gt; {\n      + manifestUrl: URI\n      + drmToken: String\n    }\n    \n    class TelemetryPayload &lt;&lt;DTO&gt;&gt; {\n      + viewerSessionId: String\n      + eventAction: Enum\n      + playbackPositionSeconds: Integer\n    }\n}\n\n&#39; Domain Logic &amp; Service Delegations\nUploadAPI --&gt; TranscodingEngine : delegates assembly\nGarbageCollectorService --&gt; UploadSession : audits lastActivity\nLiveAPI --&gt; LiveStateEngine : manages stream state\nPlaybackAPI --&gt; TokenValidator : verifies access\nPlaybackAPI ..&gt; ManifestResponse : returns\n\n&#39; Standard CRUD/Resource Links\nUploadAPI ..&gt; UploadSession : manages\nAssetsAPI ..&gt; TechnicalAsset : reads/updates\nLiveAPI ..&gt; LiveStream : configures\nPlaybackAPI ..&gt; TelemetryPayload : consumes\n\nUploadSession \&quot;1\&quot; --&gt; \&quot;1\&quot; TechnicalAsset : handles payload for\nLiveStream \&quot;1\&quot; --&gt; \&quot;0..1\&quot; TechnicalAsset : generates VOD\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="s4js0qg3NA0bRp_5JxE_-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="5467" width="19975.32" x="-668" y="-6064" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome true\nskinparam packageStyle rectangle\nskinparam linetype ortho\nskinparam nodesep 50\nskinparam ranksep 60\n\ntitle Class Diagram - Catalog Message Broker Events\n\npackage \&quot;Integration Events\&quot; {\n\n    abstract class DomainEvent &lt;&lt;Event&gt;&gt; {\n        + eventId: String\n        + timestamp: DateTime\n    }\n\n    package \&quot;Consumed Events (x-consumed-events)\&quot; {\n        class EventAssetListoParaPublicacion &lt;&lt;Consumed&gt;&gt; {\n            + assetId: String\n            + creatorId: String\n            + durationSeconds: Integer\n        }\n    }\n\n    package \&quot;Emitted Events (x-emitted-events)\&quot; {\n        \n        &#39; Lifecycle &amp; Visibility Events\n        class EventContenidoPublicado &lt;&lt;Emitted&gt;&gt; {\n            + itemId: String\n            + channelId: String\n            + categoryId: String\n            + technicalAssetId: String\n        }\n\n        class EventContenidoDespublicado &lt;&lt;Emitted&gt;&gt; {\n            + itemId: String\n        }\n\n        class EventContenidoActualizado &lt;&lt;Emitted&gt;&gt; {\n            + itemId: String\n            + updatedFields: List&lt;String&gt;\n        }\n\n        class EventContenidoEliminado &lt;&lt;Emitted&gt;&gt; {\n            + itemId: String\n            + technicalAssetId: String\n        }\n\n        &#39; Rights &amp; Restrictions Events\n        class EventReclamacionDerechosCreada &lt;&lt;Emitted&gt;&gt; {\n            + itemId: String\n            + claimId: String\n            + claimType: String\n        }\n\n        class EventReclamacionResuelta &lt;&lt;Emitted&gt;&gt; {\n            + itemId: String\n            + claimId: String\n            + resolution: String\n        }\n\n        class EventRestriccionAplicada &lt;&lt;Emitted&gt;&gt; {\n            + itemId: String\n            + restrictionType: String\n        }\n\n        class EventRestriccionLevantada &lt;&lt;Emitted&gt;&gt; {\n            + itemId: String\n            + restrictionType: String\n        }\n    }\n\n    &#39; Inheritance Mapping\n    DomainEvent &lt;|-- EventAssetListoParaPublicacion\n    \n    DomainEvent &lt;|-- EventContenidoPublicado\n    DomainEvent &lt;|-- EventContenidoDespublicado\n    DomainEvent &lt;|-- EventContenidoActualizado\n    DomainEvent &lt;|-- EventContenidoEliminado\n    \n    DomainEvent &lt;|-- EventReclamacionDerechosCreada\n    DomainEvent &lt;|-- EventReclamacionResuelta\n    DomainEvent &lt;|-- EventRestriccionAplicada\n    DomainEvent &lt;|-- EventRestriccionLevantada\n}\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="s4js0qg3NA0bRp_5JxE_-3">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="3179" width="20139.26" x="-780" y="-572" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="nAHpC_yz_rBMnKTI3ofD" name="secuencia">
    <mxGraphModel dx="771" dy="609" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam monochrome true\nskinparam style strictuml\nskinparam defaultFontName Arial\nskinparam participantPadding 20\n\ntitle Diagrama de Secuencia: Sincronía vs Asincronía\n\nactor \&quot;Client\&quot; as Client\nparticipant \&quot;API Service\&quot; as API\nqueue \&quot;Message Broker\&quot; as Broker\n\n== Synchronous: Client-API Interaction (Blocking) ==\nClient -&gt; API: GET /assets/{assetId}\nAPI --&gt; Client: 200 OK (Technical Asset Details)\n\nClient -&gt; API: POST /lives\nAPI --&gt; Client: 201 Created (Configured LiveStream)\n\n== Asynchronous: Integration Events (Fire-and-Forget) ==\nnote over API, Broker: Background processing triggers\nClient -&gt; API: POST /assets/{assetId}/upload/complete\nAPI --&gt;&gt; Broker: Emit(UploadCompleted)\nAPI --&gt;&gt; Broker: Emit(ProcessingFinished)\nAPI --&gt;&gt; Broker: Emit(AssetReady)\nAPI --&gt; Client: 202 Accepted (Processing Started)\n\n== Asynchronous: Telemetry Ingestion ==\nClient -&gt; API: POST /assets/{assetId}/telemetry\nAPI --&gt;&gt; Broker: Emit(PlaybackSessionCompleted)\nAPI --&gt; Client: 204 No Content (Ingested)\n\n== Asynchronous: Live Stream Workflow ==\nClient -&gt; API: PUT /lives/{liveId}/state (end)\nAPI --&gt;&gt; Broker: Emit(TransmisionEnVivoFinalizada)\nAPI --&gt; Client: 200 OK (Stream Ended)\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="xmi8cS3HOA-LV78vGN9y-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="763" width="610" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
