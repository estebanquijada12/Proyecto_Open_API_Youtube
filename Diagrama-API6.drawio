        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    direction TB\n    class CuentaAnunciante {\n        +UUID id\n        +String companyName\n        +String contactEmail\n        +String status\n        +registrarCuenta()\n        +obtenerDatos()\n    }\n    class DatosFacturacion {\n        +String taxId\n        +String billingAddress\n        +actualizarFacturacion()\n    }\n    class CampanaPublicitaria {\n        +UUID id\n        +String name\n        +String objective\n        +Float budget\n        +Float budgetRemaining\n        +DateTime startDate\n        +DateTime endDate\n        +String status\n        +crearCampana()\n        +listarCampanas()\n        +actualizarEstado()\n    }\n    class CreativoPublicitario {\n        +UUID id\n        +String name\n        +String assetUrl\n        +String format\n        +String validationStatus\n        +subirCreativo()\n        +listarCreativos()\n    }\n    class CriterioSegmentacion {\n        +List~String~ countries\n        +Integer minAge\n        +Integer maxAge\n        +List~String~ categories\n        +estimarInventario()\n    }\n    class DecisionEntrega {\n        +UUID adId\n        +UUID catalogItemId\n        +String creativeUrl\n        +String format\n        +decidirAnuncio()\n    }\n    class InteraccionAnuncio {\n        +UUID adId\n        +UUID catalogItemId\n        +String interactionType\n        +registrarInteraccion()\n    }\n    class MetricasCampana {\n        +Integer impressions\n        +Integer clicks\n        +Float ctr\n        +Float cpm\n        +Float totalSpent\n        +obtenerMetricas()\n        +generarReporte()\n    }\n    CuentaAnunciante \&quot;1\&quot; --&gt; \&quot;1\&quot; DatosFacturacion : posee\n    CuentaAnunciante \&quot;1\&quot; --&gt; \&quot;*\&quot; CampanaPublicitaria : administra\n    CuentaAnunciante \&quot;1\&quot; --&gt; \&quot;*\&quot; CreativoPublicitario : gestiona\n    CampanaPublicitaria \&quot;1\&quot; --&gt; \&quot;*\&quot; CreativoPublicitario : asocia\n    CampanaPublicitaria \&quot;1\&quot; --&gt; \&quot;1\&quot; CriterioSegmentacion : define target de audiencia\n    CampanaPublicitaria \&quot;1\&quot; --&gt; \&quot;1\&quot; MetricasCampana : consolida rendimiento\n    DecisionEntrega ..&gt; CreativoPublicitario : selecciona\n    InteraccionAnuncio \&quot;*\&quot; --&gt; \&quot;1\&quot; DecisionEntrega : ocurre sobre\n    InteraccionAnuncio \&quot;*\&quot; --&gt; \&quot;1\&quot; MetricasCampana : alimenta datos&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="LGDToFVbRhSlVclxcaSi-1">
